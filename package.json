{
  "name": "my-app",
  "main": "client/index.js",
  "version": "1.32.7",
  "scripts": {
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "lint": "npx expo lint --max-warnings 0",
    "lint:fix": "npx expo lint --fix",
    "check:types": "tsc --noEmit",
    "check:providers": "node scripts/check-providers.js",
    "check:providers:mock": "MOCK_PROVIDERS=1 node scripts/check-providers.js",
    "check:required": "npm run lint && npm run check:types && npm run check:format && npm run check:providers:mock && npm test -- --runInBand",
    "sync:prompts": "node scripts/sync-prompts.js",
    "check:format": "prettier --check \"**/*.{js,ts,tsx,css,json}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/drawer": "^7.7.10",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@tanstack/react-query": "^5.90.7",
    "concurrently": "^9.2.1",
    "expo": "^57.0.0",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.2",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.1",
    "expo-intent-launcher": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "0.10.0",
    "tsx": "^4.20.6",
    "wait-on": "^9.0.3",
    "ws": "^8.18.0",
    "yaml": "^2.8.3",
    "zod": "^3.24.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@react-native/jest-preset": "^0.86.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.10.0",
    "@types/react": "~19.2.4",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "prettier": "3.6.2",
    "typescript": "~6.0.3"
  },
  "private": true,
  "overrides": {
    "markdown-it": "^14.1.0"
  }
}
